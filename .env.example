PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-long-random-string

# Public URL used for generating QR codes — set this to the address your users will scan
BASE_URL=http://your-server:3000

# Active Directory / LDAP
LDAP_URL=ldap://your-ad-server:389
# Service account used to search the directory
LDAP_BIND_DN=CN=svc-pdfshare,OU=ServiceAccounts,DC=domain,DC=com
LDAP_BIND_CREDENTIALS=service-account-password
# Base OU where user accounts live
LDAP_SEARCH_BASE=OU=Users,DC=domain,DC=com
# Filter to match the login username — {{username}} is replaced at runtime
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# SMB Share — use forward or backward slashes
SMB_SHARE=//fileserver/pdf-share
SMB_DOMAIN=YOURDOMAIN
SMB_USERNAME=smb-reader
SMB_PASSWORD=smb-password
